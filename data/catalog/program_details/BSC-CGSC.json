ew/667f2cbbc53c170e3f0cb23e\" target=\"_blank\">EOS416</a> <!-- -->-<!-- --> <!-- -->High Temperature Petrology<!-- --> <span style=\"margin-left:5px\">(1.5)</span></span></li><li><span><a href=\"#/courses/view/6686d77d848b0513cf921372\" target=\"_blank\">EOS425</a> <!-- -->-<!-- --> <!-- -->Aqueous Chemistry in the Earth and Ocean<!-- --> <span style=\"margin-left:5px\">(1.5)</span></span></li></ul></div></div></li><li data-test=\"ruleView-H\"><div data-test=\"ruleView-H-result\">Complete <span>1</span> of: <div><ul style=\"margin-top:5px;margin-bottom:5px\"><li><span><a href=\"#/courses/view/5e615df5109f5025006793a7\" target=\"_blank\">STAT255</a> <!-- -->-<!-- --> <!-- -->Statistics for Life Sciences I<!-- --> <span style=\"margin-left:5px\">(1.5)</span></span></li><li><span><a href=\"#/courses/view/5e615e517eb8e0250078b7da\" target=\"_blank\">STAT260</a> <!-- -->-<!-- --> <!-- -->Introduction to Probability and Statistics I<!-- --> <span style=\"margin-left:5px\">(1.5)</span></span></li></ul></div></div></li><li data-test=\"ruleView-I\"><div data-test=\"ruleView-I-result\">Complete <span>9</span> units of electives</div></li></ul></li></ul></div><div></div></div></section></div>",
